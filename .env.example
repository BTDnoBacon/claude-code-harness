# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens or URLs.

# Discord: Server Settings → Integrations → Webhooks → Copy Webhook URL
# Used by scripts/notify.sh to send outbound notifications
DISCORD_WEBHOOK_URL=

# Slack: api.slack.com → Your Apps → Incoming Webhooks → Webhook URL
SLACK_WEBHOOK_URL=

# Discord Bot (for inbound commands via bot.js)
# Discord Developer Portal → Your App → Bot → Reset Token
DISCORD_BOT_TOKEN=

# The channel ID where the bot listens for commands
# Right-click channel → Copy Channel ID (Developer Mode must be on)
DISCORD_CHANNEL_ID=
